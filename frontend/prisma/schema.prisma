// VinFast AI Sales Assistant - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Lead (Customer interested in buying)
model Lead {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String?
  passengers    Int      @default(4)
  monthlyKm     Int      @default(1500)
  monthlyIncome Int      @default(0)
  monthlyBudget Int      @default(0)
  downPayment   Int      @default(0)
  usage         String   @default("[]") // JSON array of usage strings
  notes         String?
  status        String   @default("new") // new, contacted, booked, purchased, lost
  source        String   @default("ai-chat") // ai-chat, website, zalo
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions ChatSession[]
}

// Chat session (conversation between user and AI)
model ChatSession {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  phase       String   @default("idle")
  messages    String   @default("[]") // JSON array of messages
  selectedCar String?
  showroomId  String?
  slotDate    String?
  slotTime    String?
  status      String   @default("active") // active, completed, handed_off
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
